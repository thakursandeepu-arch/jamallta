{
  "functions": [
    {
      "source": "customer/functions",
      "codebase": "customer"
    },
    {
      "source": "auth-functions",
      "codebase": "authsync"
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase.email.json",
      ".firebaserc",
      "deploy.log",
      "*.log",
      "# Code Citations.md",
      ".git/**",
      ".firebase/**",
      "auth-functions/**",
      "customer/functions/**",
      "email-functions/**",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
